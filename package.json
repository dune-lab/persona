{
  "name": "persona",
  "version": "1.0.0",
  "license": "MIT",
  "prettier": "@enxoval/quality/prettier",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node --env-file=.env dist/src/server.js",
    "lint": "prettier --check src && eslint src --max-warnings 0",
    "lint-fix": "prettier --write src && eslint src --fix",
    "migration:generate": "f() { node node_modules/@enxoval/db/dist/cli/generate.js src/db/migrations/$1; }; f",
    "migration:run": "node node_modules/@enxoval/db/dist/cli/run.js",
    "migration:revert": "node node_modules/@enxoval/db/dist/cli/revert.js",
    "test": "vitest run --config node_modules/@enxoval/testing/dist/vitest.config.js",
    "unit": "vitest run --config node_modules/@enxoval/testing/dist/vitest.config.js --project unit",
    "integration": "vitest run --config node_modules/@enxoval/testing/dist/vitest.config.js --project integration"
  },
  "dependencies": {
    "@enxoval/db": "^1.0.1",
    "@enxoval/http": "^1.0.1",
    "@enxoval/observability": "^1.0.1",
    "@enxoval/types": "^1.0.1"
  },
  "devDependencies": {
    "@enxoval/quality": "^1.0.1",
    "@enxoval/testing": "^1.0.1",
    "@types/node": "^24.0.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
